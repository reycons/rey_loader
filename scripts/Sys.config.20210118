  </FTP>
  <Copy>
    <Folder>
      <From>D:\Navi\Sync\ABN\LupoSecurities\</From>
      <To>D:\WQT\Sync\ABNAmro\Sallerson\</To>
      <Filter>*[DateString]*</Filter>
      <DateFormat>yyyMMdd</DateFormat>
      <Lookback>-1</Lookback>
		<LookbackPeriod>day</LookbackPeriod>
	</Folder>
    <Folder>
      <From>D:\Navi\Sync\ABN\LupoFutures\</From>
