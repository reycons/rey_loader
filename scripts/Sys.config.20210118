<Configuration>
  <Notes>
    <Note>
		  Use this command to create securestring for the password and user names
		  read-host "Enter Password or UserName" -AsSecureString | convertFrom-SecureString

	  </Note>
    <Note>Copy Section can be used to sync folder across windows servers also</Note>
  </Notes>
  <SQLServer Notes="This does not run when using the scheduler">
    <Server Name="(Local)" Database="NaviControl">
      <Commands>
		  <Command Alias ="Load all files" Order="6" sql="execute NaviControl.[dbo].[pBCP_NewFiles]">
		  </Command>
		  <!--<Command Alias ="Futures MICS_Bal" Order="1" sql="execute NaviControl.dbo.pBCP_FileByID 108">
        </Command>
        <Command Alias ="Futures MICS_Cash" Order="2" sql="execute NaviControl.dbo.pBCP_FileByID 109">
        </Command>
        <Command Alias ="Securities MICS_Bal" Order="3" sql="execute NaviControl.dbo.pBCP_FileByID 79">
        </Command>
        <Command Alias ="Securities MICS_Cash" Order="4" sql="execute NaviControl.dbo.pBCP_FileByID 80">
        </Command>
		  <Command Alias ="Futures MICS trade" Order="5" sql="execute NaviControl.dbo.pBCP_FileByID 121">
		  </Command>-->
	  </Commands>
    </Server>
  </SQLServer>
  <IndexHeader>
    <HeaderRow>LogName|LogDate|LogRunTime|FileName|FileLength|FileDate|RowCount|Header</HeaderRow>
  </IndexHeader>
  <IndexLocations>
    <IndexFileName>D:\Navi\Bin\Index\HandleFiles.[Name].[DateString].index</IndexFileName>
    <IndexLocation ExpandFiles="True"> 
      <Name>MICSFutures</Name>
      <Folder>D:\Navi\Sync\ABN\LupoSecurities\*[DateString]*.csv</Folder>
      <DateFormat>yyyMMdd</DateFormat>
      <Lookback>-1</Lookback>
		<LookbackPeriod>day</LookbackPeriod>
	</IndexLocation>
    <IndexLocation ExpandFiles="True">
      <Name>MICSSecurities</Name>
      <Folder>D:\Navi\Sync\ABN\LupoFutures\*[DateString]*.csv</Folder>
      <DateFormat>yyyMMdd</DateFormat>
      <Lookback>-1</Lookback>
		<LookbackPeriod>day</LookbackPeriod>
	</IndexLocation>
	  <IndexLocation>
		  <Name>EDFMan</Name>
		  <Folder>D:\Navi\Sync\EDFMan\LupoSecurities\[DateString]\*.csv</Folder>
		  <DateFormat>yyyMMdd</DateFormat>
		  <Lookback>-1</Lookback>
		  <LookbackPeriod>day</LookbackPeriod>
	  </IndexLocation>
	  <IndexLocation>
		  <Name>Wedbush</Name>
		  <Folder>D:\Navi\Sync\Wedbush\*[DateString].csv</Folder>
		  <DateFormat>yyyMMdd</DateFormat>
		  <Lookback>-1</Lookback>
		  <LookbackPeriod>day</LookbackPeriod>
	  </IndexLocation>
	  <IndexLocation>
		  <Name>Matrix</Name>
		  <Folder>D:\Navi\Sync\Matrix\[DateString]_*.csv</Folder>
		  <DateFormat>yyyMM01</DateFormat>
		  <Lookback>-1</Lookback>
		  <LookbackPeriod>month</LookbackPeriod>
	  </IndexLocation>
  </IndexLocations>
  <FTP>
    <StartTime>9/23/2019 1:24:08 PM</StartTime>
    <EndTime>9/23/2019 1:24:29 PM</EndTime>
    <PSFTPPath>D:\Navi\Bin\psftp.exe</PSFTPPath>

