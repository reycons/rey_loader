      <Filter>*[DateString]*</Filter>
      <DateFormat>yyyMMdd</DateFormat>
      <Lookback>-1</Lookback>
		<LookbackPeriod>day</LookbackPeriod>
	</Folder>
  </Copy>
	<FileCompression Description="This section defines how file compression will be treated">
		<ExpandFiles Description="Define how to uncompress files">

			<File Name="D:\Navi\Sync\ABN\LupoSecurities\*[DateString]*.csv.zip"
				  Destination="D:\Navi\Sync\ABN\LupoSecurities"
				  Overwrite="True"
				  KeepZip="False"
				  DateFormat="yyyMMdd"
				  Lookback="-1">
				
			</File>
			<File Name="D:\Navi\Sync\ABN\LupoFutures\*[DateString]*.csv.zip"
				  Destination="D:\Navi\Sync\ABN\LupoFutures"
				  Overwrite="True"
				  KeepZip="False"
				  DateFormat="yyyMMdd"
				  Lookback="-1">

			</File>
		</ExpandFiles>
	</FileCompression>
</Configuration>