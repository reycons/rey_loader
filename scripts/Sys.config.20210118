      <SshHostKeyFingerprint>ssh-dss 1024 1FxM1gax1xdrEEpYPUh29F2YvieU75Wz/ZVzvWEGlgo=</SshHostKeyFingerprint>
      <UserName>sallersonftp</UserName>
		<UsePrivateKey>True</UsePrivateKey>
		<PrivateKey>D:\Navi\Bin\Keys\ABN\PrivateKey.ppk </PrivateKey>	
      <Password></Password>
