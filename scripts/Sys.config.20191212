<Configuration>
  <Notes>
    <Note>
		  Use this command to create securestring for the password and user names
		  read-host "Enter Password or UserName" -AsSecureString | convertFrom-SecureString

	  </Note>
    <Note>Copy Section can be used to sync folder across windows servers also</Note>
  </Notes>
  <SQLServer>
    <Server Name="(Local)" Database="NaviControl">
      <Commands>
        <Command Order="1" sql="execute NaviControl.dbo.pBCP_FileByID 108">
        </Command>
        <Command Order="2" sql="execute NaviControl.dbo.pBCP_FileByID 109">
        </Command>
        <Command Order="3" sql="execute NaviControl.dbo.pBCP_FileByID 79">
        </Command>
        <Command Order="4" sql="execute NaviControl.dbo.pBCP_FileByID 80">
        </Command>
      </Commands>
    </Server>
  </SQLServer>
  <IndexHeader>
    <HeaderRow>LogName|LogDate|LogRunTime|FileName|FileLength|FileDate|RowCount|Header</HeaderRow>
  </IndexHeader>
  <IndexLocations>
    <IndexFileName>D:\Navi\Bin\Index\HandleFiles.[Name].[DateString].index</IndexFileName>
    <IndexLocation>
      <Name>MICSFutures</Name>
      <Folder>D:\Navi\Sync\ABN\LupoSecurities\MICS*[DateString]*.csv</Folder>
      <DateFormat>yyyMMdd</DateFormat>
      <Lookback>-1</Lookback>
    </IndexLocation>
    <IndexLocation>
      <Name>MICSSecurities</Name>
      <Folder>D:\Navi\Sync\ABN\LupoFutures\MICS*[DateString]*.csv</Folder>
      <DateFormat>yyyMMdd</DateFormat>
      <Lookback>-1</Lookback>
    </IndexLocation>
	  <IndexLocation>
		  <Name>EDFMan</Name>
		  <Folder>D:\Navi\Sync\EDFMan\Lupo\[DateString]\*.csv</Folder>
		  <DateFormat>yyyMMdd</DateFormat>
		  <Lookback>-1</Lookback>
	  </IndexLocation>
  </IndexLocations>
  <FTP>
    <StartTime>9/23/2019 1:24:08 PM</StartTime>
    <EndTime>9/23/2019 1:24:29 PM</EndTime>
    <PSFTPPath>D:\Navi\Bin\psftp.exe</PSFTPPath>
    <Server Description="ABN Amro wspftp previous trading day files">
      <FTPCommandFile>D:\Navi\Bin\ftp\FuturesCommands.ftp</FTPCommandFile>
      <HostName>sftp.us.abnamroclearing.com</HostName>
      <Protocol>Sftp</Protocol>
      <SshHostKeyFingerprint>ssh-dss 1024 1FxM1gax1xdrEEpYPUh29F2YvieU75Wz/ZVzvWEGlgo=</SshHostKeyFingerprint>
      <UserName>wspftp</UserName>
      <Password></Password>
      <Commands>
  lcd D:\Navi\Sync\ABN\MICSFutures\
  mget ./MICS/*[DateString]*
  lcd D:\Navi\Sync\ABN\LupoFutures
  mget *[DateString]*
  quit
	  </Commands>
      <DateFormat>yyyMMdd</DateFormat>
      <Lookback>-1</Lookback>
    </Server>
    <Server Description="ABN Amro sallersonftp previous trading day files">
      <FTPCommandFile>D:\Navi\Bin\ftp\SecuritiesCommands.ftp</FTPCommandFile>
      <HostName>sftp.us.abnamroclearing.com</HostName>
